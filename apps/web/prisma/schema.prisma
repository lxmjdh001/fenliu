generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  member
}

enum MembershipLevel {
  free
  vip
}

enum UserStatus {
  active
  banned
}

enum Platform {
  whatsapp
  telegram
  line
}

enum ServiceStatus {
  enabled
  paused
  expired
}

enum AccessRule {
  random
  sequence
}

enum WhatsAppEntry {
  wa_me
  api_send
}

enum GreetingMode {
  none
  single
  batch
}

enum PublishStatus {
  success
  pending
  failed
}

enum OrderStatus {
  pending
  paid
  cancelled
  refunded
}

enum SnapshotStatus {
  success
  failed
}

model User {
  id                  Int              @id @default(autoincrement())
  email               String           @unique
  name                String
  passwordHash        String           @map("password_hash")
  role                UserRole         @default(member)
  membershipLevel     MembershipLevel  @default(free) @map("membership_level")
  membershipExpiresAt DateTime?        @map("membership_expires_at")
  status              UserStatus       @default(active)
  createdAt           DateTime         @default(now()) @map("created_at")
  updatedAt           DateTime         @updatedAt @map("updated_at")
  sessions            Session[]
  memberships         Membership[]
  orders              Order[]
  services            Service[]

  @@map("users")
}

model Session {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int      @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model Plan {
  id                   Int          @id @default(autoincrement())
  name                 String
  priceCents           Int          @default(0) @map("price_cents")
  durationDays         Int          @default(30) @map("duration_days")
  maxServices          Int          @default(10) @map("max_services")
  maxTargetsPerService Int          @default(5000) @map("max_targets_per_service")
  allowIpLock          Boolean      @default(true) @map("allow_ip_lock")
  allowEdgeBlock       Boolean      @default(true) @map("allow_edge_block")
  status               String       @default("active")
  createdAt            DateTime     @default(now()) @map("created_at")
  updatedAt            DateTime     @updatedAt @map("updated_at")
  memberships          Membership[]
  orders               Order[]

  @@map("plans")
}

model Membership {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  planId    Int?     @map("plan_id")
  startsAt  DateTime @default(now()) @map("starts_at")
  expiresAt DateTime @map("expires_at")
  status    String   @default("active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan      Plan?    @relation(fields: [planId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([expiresAt])
  @@map("memberships")
}

model Order {
  id              Int         @id @default(autoincrement())
  userId          Int         @map("user_id")
  planId          Int?        @map("plan_id")
  amountCents     Int         @default(0) @map("amount_cents")
  status          OrderStatus @default(pending)
  provider        String      @default("")
  providerOrderId String      @default("") @map("provider_order_id")
  paidAt          DateTime?   @map("paid_at")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan            Plan?       @relation(fields: [planId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
  @@map("orders")
}

model Service {
  id                  Int               @id @default(autoincrement())
  userId              Int               @map("user_id")
  name                String
  platform            Platform
  shortCode           String            @unique @map("short_code")
  domain              String
  status              ServiceStatus     @default(enabled)
  accessRule          AccessRule        @default(random) @map("access_rule")
  whatsappEntry       WhatsAppEntry     @default(wa_me) @map("whatsapp_entry")
  lockIP              Boolean           @default(false) @map("lock_ip")
  ipLockGroupId       String            @map("ip_lock_group_id")
  greetingMode        GreetingMode      @default(none) @map("greeting_mode")
  globalGreeting      String            @default("") @map("global_greeting")
  greetingPool        Json              @default("[]") @map("greeting_pool")
  edgeBlock           Json              @map("edge_block")
  publishStatus       PublishStatus     @default(pending) @map("publish_status")
  publishError        String            @default("") @map("publish_error")
  publishedAt         DateTime?         @map("published_at")
  membershipExpiresAt DateTime?         @map("membership_expires_at")
  todayPv             Int               @default(0) @map("today_pv")
  todayUv             Int               @default(0) @map("today_uv")
  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime          @updatedAt @map("updated_at")
  user                User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  targets             ServiceTarget[]
  publishSnapshots    PublishSnapshot[]

  @@index([userId])
  @@index([platform])
  @@index([updatedAt])
  @@map("services")
}

model ServiceTarget {
  id            Int      @id @default(autoincrement())
  serviceId     Int      @map("service_id")
  targetKey     String   @map("target_key")
  url           String
  normalizedUrl String   @map("normalized_url")
  remark        String   @default("")
  greeting      String   @default("")
  enabled       Boolean  @default(true)
  sortOrder     Int      @default(0) @map("sort_order")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  service       Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([serviceId, targetKey])
  @@index([serviceId, sortOrder])
  @@map("service_targets")
}

model PublishSnapshot {
  id                  Int            @id @default(autoincrement())
  serviceId           Int            @map("service_id")
  routeKey            String         @map("route_key")
  serviceKey          String         @map("service_key")
  routeSnapshotJson   Json           @map("route_snapshot_json")
  serviceSnapshotJson Json           @map("service_snapshot_json")
  status              SnapshotStatus @default(success)
  error               String         @default("")
  createdAt           DateTime       @default(now()) @map("created_at")
  service             Service        @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([serviceId])
  @@index([createdAt])
  @@map("publish_snapshots")
}
